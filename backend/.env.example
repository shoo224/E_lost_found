# E Lost & Found - Copy this file to .env and fill in your values
# Never commit .env to git

# MongoDB Atlas connection string (get from Atlas Console > Connect)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/elostfound?retryWrites=true&w=majority

# JWT - use a long random string in production (e.g. openssl rand -hex 32)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# OTP - how long OTP codes are valid (minutes)
OTP_EXPIRE_MINUTES=10

# AWS - for S3 (image uploads) and SES (email)
# Create IAM user with S3 + SES permissions, then create access keys
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-south-1
S3_BUCKET=elost-found-uploads

# Email - prefer SES in production; SMTP as fallback
SES_FROM_EMAIL=noreply@yourdomain.com
# SMTP (optional - used if SES not configured or for dev)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com

# CORS - comma-separated origins (e.g. http://localhost:5500, http://127.0.0.1:5500)
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:8000

# Admin - email(s) that get admin role (comma-separated)
ADMIN_EMAILS=admin@college.edu
# Admin panel password (email + password login without OTP, for admin.html only)
ADMIN_PANEL_PASSWORD=change-this-admin-password

# API base URL for frontend (e.g. http://localhost:8000)
API_BASE_URL=http://localhost:8000
